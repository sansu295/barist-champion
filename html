<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Costa Coffee Barista Certification Quiz</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            costa: {
              burgundy: '#6B1D2F',
              dark: '#4A121F',
              gold: '#D4A359',
              cream: '#FAF6F0',
              soft: '#F2EBE5',
              accent: '#8B263E'
            }
          }
        }
      }
    }
  </script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
  </style>
</head>
<body class="bg-costa-cream min-h-screen text-slate-800 flex flex-col">

  <!-- Navigation Bar -->
  <header class="bg-costa-burgundy text-white shadow-md sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <div class="bg-costa-gold p-2 rounded-lg text-costa-dark font-black">
          <i data-lucide="coffee" class="w-6 h-6"></i>
        </div>
        <div>
          <h1 class="font-extrabold text-lg md:text-xl tracking-tight">COSTA BARISTA CERTIFICATION</h1>
          <p class="text-xs text-costa-gold font-medium">120 Question Master Question Bank</p>
        </div>
      </div>
      <div id="userBadge" class="hidden flex items-center space-x-3 bg-costa-dark/60 px-3 py-1.5 rounded-full border border-costa-gold/30">
        <span class="text-sm font-semibold text-costa-gold" id="displayName">Barista</span>
        <button onclick="logout()" class="text-xs text-red-300 hover:text-white transition flex items-center gap-1">
          <i data-lucide="log-out" class="w-3.5 h-3.5"></i> Logout
        </button>
      </div>
    </div>
  </header>

  <!-- Main Container -->
  <main class="flex-1 max-w-4xl w-full mx-auto p-4 md:p-6 my-4">

    <!-- VIEW 1: USER LOGIN / REGISTER -->
    <div id="loginView" class="max-w-md mx-auto bg-white rounded-2xl shadow-xl p-6 md:p-8 border border-amber-100">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-costa-burgundy text-costa-gold rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg">
          <i data-lucide="award" class="w-8 h-8"></i>
        </div>
        <h2 class="text-2xl font-bold text-costa-burgundy">Barista Login</h2>
        <p class="text-sm text-slate-500 mt-1">Enter your name and store ID to start a 20-question randomized test.</p>
      </div>

      <form id="loginForm" onsubmit="handleLogin(event)" class="space-y-4">
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Full Name</label>
          <div class="relative">
            <i data-lucide="user" class="w-5 h-5 absolute left-3 top-3 text-slate-400"></i>
            <input type="text" id="usernameInput" required placeholder="e.g. Alex Morgan" class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-costa-burgundy focus:outline-none" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Store / Employee ID</label>
          <div class="relative">
            <i data-lucide="building-2" class="w-5 h-5 absolute left-3 top-3 text-slate-400"></i>
            <input type="text" id="storeInput" required placeholder="e.g. DXB-042" class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-costa-burgundy focus:outline-none" />
          </div>
        </div>
        <button type="submit" class="w-full bg-costa-burgundy hover:bg-costa-dark text-white font-bold py-3 rounded-xl shadow-lg hover:shadow-xl transition flex items-center justify-center space-x-2">
          <span>Start Assessment</span>
          <i data-lucide="arrow-right" class="w-5 h-5"></i>
        </button>
      </form>

      <!-- Mini Leaderboard Preview -->
      <div class="mt-8 pt-6 border-t border-slate-100">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center justify-between">
          <span>Top Barista Leaderboard</span>
          <i data-lucide="trophy" class="w-4 h-4 text-costa-gold"></i>
        </h3>
        <div id="miniLeaderboard" class="space-y-2 text-sm"></div>
      </div>
    </div>

    <!-- VIEW 2: DASHBOARD HOME -->
    <div id="dashboardView" class="hidden space-y-6">
      <div class="bg-white rounded-2xl shadow-sm p-6 border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <span class="text-xs font-bold text-costa-gold uppercase tracking-wider">Welcome back</span>
          <h2 class="text-2xl font-extrabold text-costa-burgundy" id="welcomeUser">Barista Name</h2>
          <p class="text-sm text-slate-500">Each quiz draws <span class="font-bold text-slate-700">20 unique questions</span> randomly from our official 120-item bank.</p>
        </div>
        <button onclick="startNewQuiz()" class="w-full md:w-auto bg-costa-burgundy hover:bg-costa-dark text-white font-bold px-6 py-3 rounded-xl shadow-md transition flex items-center justify-center space-x-2">
          <i data-lucide="play-circle" class="w-5 h-5"></i>
          <span>Start New 20-Q Quiz</span>
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
          <div class="p-3 bg-amber-50 text-costa-gold rounded-xl">
            <i data-lucide="check-circle-2" class="w-6 h-6"></i>
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Total Quizzes Taken</p>
            <p class="text-xl font-bold text-slate-800" id="statQuizzes">0</p>
          </div>
        </div>
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
          <div class="p-3 bg-emerald-50 text-emerald-600 rounded-xl">
            <i data-lucide="target" class="w-6 h-6"></i>
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Highest Score</p>
            <p class="text-xl font-bold text-slate-800" id="statHighScore">0 / 20</p>
          </div>
        </div>
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex items-center space-x-4">
          <div class="p-3 bg-purple-50 text-purple-600 rounded-xl">
            <i data-lucide="help-circle" class="w-6 h-6"></i>
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Question Pool</p>
            <p class="text-xl font-bold text-slate-800">120 Items</p>
          </div>
        </div>
      </div>

      <!-- Live Leaderboard -->
      <div class="bg-white rounded-2xl shadow-sm p-6 border border-slate-100">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-costa-burgundy flex items-center gap-2">
            <i data-lucide="trophy" class="w-5 h-5 text-costa-gold"></i>
            <span>Live Barista Leaderboard</span>
          </h3>
          <button onclick="renderLeaderboard()" class="text-xs text-costa-burgundy hover:underline font-semibold flex items-center gap-1">
            <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i> Refresh
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-slate-200 text-xs uppercase text-slate-400 font-bold">
                <th class="py-3 px-2">Rank</th>
                <th class="py-3 px-2">Barista</th>
                <th class="py-3 px-2">Store ID</th>
                <th class="py-3 px-2 text-right">Best Score</th>
                <th class="py-3 px-2 text-right">Date</th>
              </tr>
            </thead>
            <tbody id="fullLeaderboardTable" class="divide-y divide-slate-100 text-sm"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- VIEW 3: ACTIVE QUIZ VIEW -->
    <div id="quizView" class="hidden space-y-6">
      <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <span class="text-xs font-bold text-costa-gold uppercase tracking-wider">Active Certification Quiz</span>
          <h2 class="text-lg font-bold text-slate-800" id="questionTracker">Question 1 of 20</h2>
        </div>
        <div class="w-full sm:w-48 bg-slate-100 rounded-full h-3 overflow-hidden">
          <div id="progressBar" class="bg-costa-burgundy h-full w-0 transition-all duration-300"></div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-md p-6 md:p-8 border border-slate-100 relative">
        <h3 id="questionText" class="text-lg md:text-xl font-bold text-slate-900 mb-6 leading-relaxed"></h3>
        <div id="optionsContainer" class="space-y-3"></div>

        <div class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between">
          <button id="prevBtn" onclick="navigateQuestion(-1)" class="px-4 py-2.5 rounded-xl border border-slate-200 text-slate-600 font-semibold text-sm hover:bg-slate-50 transition flex items-center gap-1.5">
            <i data-lucide="chevron-left" class="w-4 h-4"></i> Previous
          </button>
          <div class="flex items-center gap-2">
            <button id="nextBtn" onclick="navigateQuestion(1)" class="px-5 py-2.5 rounded-xl bg-costa-burgundy text-white font-semibold text-sm hover:bg-costa-dark transition flex items-center gap-1.5 shadow-md">
              Next <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </button>
            <button id="submitBtn" onclick="confirmSubmitQuiz()" class="hidden px-6 py-2.5 rounded-xl bg-emerald-600 text-white font-bold text-sm hover:bg-emerald-700 transition shadow-lg flex items-center gap-1.5">
              <i data-lucide="check-circle" class="w-4 h-4"></i> Submit Test
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- VIEW 4: QUIZ RESULT SUMMARY WITH DETAILED WRONG ANSWER FILTER -->
    <div id="resultView" class="hidden space-y-6">
      <div class="bg-white rounded-2xl shadow-md p-6 md:p-8 text-center border border-slate-100">
        <div id="scoreBadge" class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-extrabold shadow-lg"></div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-costa-burgundy" id="resultTitle">Assessment Completed</h2>
        <p class="text-sm text-slate-500 mt-1" id="resultSubtitle">Here is your detailed breakdown for this 20-question test.</p>

        <div class="my-6 inline-flex items-center space-x-6 bg-slate-50 px-6 py-3 rounded-2xl border border-slate-200">
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase">Score</p>
            <p class="text-2xl font-black text-slate-800" id="finalScoreText">18 / 20</p>
          </div>
          <div class="h-8 w-px bg-slate-200"></div>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase">Percentage</p>
            <p class="text-2xl font-black text-costa-burgundy" id="finalPercentageText">90%</p>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-3">
          <button onclick="startNewQuiz()" class="bg-costa-burgundy hover:bg-costa-dark text-white font-bold px-6 py-3 rounded-xl shadow-md transition flex items-center gap-2">
            <i data-lucide="rotate-ccw" class="w-4 h-4"></i> Try Another 20 Questions
          </button>
          <button onclick="showView('dashboardView')" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-6 py-3 rounded-xl transition flex items-center gap-2">
            <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Return to Dashboard
          </button>
        </div>
      </div>

      <!-- Filterable Wrong & Correct Answers Section -->
      <div class="bg-white rounded-2xl shadow-sm p-6 border border-slate-100">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6 pb-4 border-b border-slate-100">
          <div>
            <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
              <i data-lucide="file-check-2" class="w-5 h-5 text-costa-gold"></i>
              <span>Answer Corrections & Review</span>
            </h3>
            <p class="text-xs text-slate-400 mt-0.5">Filter questions below to focus on your incorrect answers.</p>
          </div>

          <!-- Filter Buttons -->
          <div class="flex items-center bg-slate-100 p-1 rounded-xl text-xs font-bold">
            <button id="filterAllBtn" onclick="setReviewFilter('all')" class="px-3 py-1.5 rounded-lg bg-white text-slate-800 shadow-sm transition">All (20)</button>
            <button id="filterWrongBtn" onclick="setReviewFilter('wrong')" class="px-3 py-1.5 rounded-lg text-slate-500 hover:text-slate-800 transition">Incorrect Only</button>
            <button id="filterCorrectBtn" onclick="setReviewFilter('correct')" class="px-3 py-1.5 rounded-lg text-slate-500 hover:text-slate-800 transition">Correct Only</button>
          </div>
        </div>

        <div id="reviewContainer" class="space-y-4"></div>
      </div>
    </div>

  </main>

  <footer class="bg-white border-t border-slate-200 py-4 text-center text-xs text-slate-400">
    <p>© 2026 Costa Coffee UAE — Official Brand Excellence & Calibration Assessment Tool</p>
  </footer>

  <script>
    const MASTER_QUESTIONS = [
      { q: "What are the correct specifications for a Standard Single Espresso?", o: ["1 Shot, 20mls / 20g – 15 Seconds", "1 Shot, 30mls / 30g – 20 Seconds", "2 Shots, 60mls / 60g – 20 Seconds", "1 Shot, 30mls / 30g – 15 Seconds"], a: 1 },
      { q: "What are the specifications for a Decaf Single Espresso?", o: ["1 Pod, 1 Shot, 20mls / 20g – 15 Seconds", "1 Pod, 1 Shot, 30mls / 30g – 20 Seconds", "2 Pods, 1 Shot, 30mls / 30g – 20 Seconds", "1 Pod, 2 Shots, 60mls / 60g – 20 Seconds"], a: 1 },
      { q: "What is the liquid volume and output weight of a Standard Double Espresso?", o: ["40mls / 40g", "30mls / 30g", "60mls / 60g", "80mls / 80g"], a: 2 },
      { q: "How many shots and what extraction time are required for a Standard Double Espresso?", o: ["2 Shots – 15 Seconds", "2 Shots – 20 Seconds", "1 Shot – 20 Seconds", "2 Shots – 35 Seconds"], a: 1 },
      { q: "How many decaf pods are required for a Decaf Double Espresso?", o: ["2 Pods", "1 Pod", "3 Pods", "None"], a: 1 },
      { q: "What is the extraction time for a Standard Single Ristretto?", o: ["20 Seconds", "5 Seconds", "15 Seconds", "35 Seconds"], a: 2 },
      { q: "What are the shot count and liquid measurement for a Standard Single Ristretto?", o: ["1 Shot, 30mls / 30g", "1 Shot, 20mls / 20g", "2 Shots, 40mls / 40g", "1 Shot, 10mls / 10g"], a: 1 },
      { q: "What are the complete specifications for a Decaf Single Ristretto?", o: ["1 Pod, 1 Shot, 20mls / 20g – 15 Seconds", "1 Pod, 1 Shot, 30mls / 30g – 20 Seconds", "1 Pod, 2 Shots, 40mls / 40g – 15 Seconds", "2 Pods, 1 Shot, 20mls / 20g – 15 Seconds"], a: 0 },
      { q: "What are the specifications for a Standard Double Ristretto?", o: ["2 Shots, 60mls / 60g – 20 Seconds", "2 Shots, 40mls / 40g – 15 Seconds", "2 Shots, 30mls / 30g – 15 Seconds", "1 Shot, 40mls / 40g – 15 Seconds"], a: 1 },
      { q: "What are the specifications for a Decaf Double Ristretto?", o: ["2 Pods, 2 Shots, 40mls / 40g – 15 Seconds", "1 Pod, 2 Shots, 60mls / 60g – 20 Seconds", "1 Pod, 2 Shots, 40mls / 40g – 15 Seconds", "1 Pod, 1 Shot, 20mls / 20g – 15 Seconds"], a: 2 },
      { q: "What is the difference in extraction time between a Single Espresso and a Single Ristretto?", o: ["Single Espresso is 15s; Single Ristretto is 20s", "Single Espresso is 20s; Single Ristretto is 15s", "Both are 20s", "Both are 15s"], a: 1 },
      { q: "What is the difference in volume between a Double Espresso and a Double Ristretto?", o: ["Double Espresso is 60mls; Double Ristretto is 40mls", "Double Espresso is 40mls; Double Ristretto is 60mls", "Double Espresso is 80mls; Double Ristretto is 60mls", "Both are 60mls"], a: 0 },
      { q: "How many decaf pods are used for a Decaf Single Espresso vs. a Decaf Double Espresso?", o: ["Single uses 1 Pod; Double uses 2 Pods", "Single uses 2 Pods; Double uses 1 Pod", "Both use 1 Pod", "Both use 2 Pods"], a: 2 },
      { q: "What is the output weight of a Standard Single Espresso?", o: ["20g", "30g", "40g", "60g"], a: 1 },
      { q: "What is the output volume of a Standard Double Ristretto?", o: ["20mls", "30mls", "40mls", "60mls"], a: 2 },
      { q: "Does the extraction time change between Standard Single Espresso and Decaf Single Espresso?", o: ["Yes, Decaf takes 15 seconds", "Yes, Decaf takes 25 seconds", "No, both take 20 Seconds", "No, both take 15 Seconds"], a: 2 },
      { q: "Does the extraction time change between Standard Double Ristretto and Decaf Double Ristretto?", o: ["Yes, Decaf takes 20 seconds", "No, both take 15 Seconds", "No, both take 20 Seconds", "Yes, Standard takes 20 seconds"], a: 1 },
      { q: "What is the shot count for a Standard Single Ristretto?", o: ["1 Shot", "2 Shots", "3 Shots", "Half Shot"], a: 0 },
      { q: "What is the weight output for a Decaf Double Espresso?", o: ["30g", "40g", "60g", "90g"], a: 2 },
      { q: "What is the shot count for a Standard Double Espresso?", o: ["1 Shot", "2 Shots", "3 Shots", "4 Shots"], a: 1 }
    ];

    let currentUser = null;
    let activeQuizQuestions = [];
    let userAnswers = {};
    let currentQuestionIndex = 0;
    let activeFilter = 'all';

    window.addEventListener('DOMContentLoaded', () => {
      lucide.createIcons();
      checkAuth();
      renderMiniLeaderboard();
      renderLeaderboard();
    });

    function showView(viewId) {
      ['loginView', 'dashboardView', 'quizView', 'resultView'].forEach(id => {
        document.getElementById(id).classList.add('hidden');
      });
      document.getElementById(viewId).classList.remove('hidden');
      window.scrollTo(0, 0);
    }

    function checkAuth() {
      const stored = localStorage.getItem('costa_barista_user');
      if (stored) {
        currentUser = JSON.parse(stored);
        document.getElementById('displayName').textContent = currentUser.name;
        document.getElementById('welcomeUser').textContent = currentUser.name;
        document.getElementById('userBadge').classList.remove('hidden');
        updateUserStats();
        showView('dashboardView');
      } else {
        document.getElementById('userBadge').classList.add('hidden');
        showView('loginView');
      }
    }

    function handleLogin(e) {
      e.preventDefault();
      const name = document.getElementById('usernameInput').value.trim();
      const store = document.getElementById('storeInput').value.trim();
      if (!name || !store) return;

      currentUser = {
        name,
        store,
        id: name.toLowerCase().replace(/\s+/g, '_') + '_' + store.toLowerCase()
      };

      localStorage.setItem('costa_barista_user', JSON.stringify(currentUser));
      document.getElementById('displayName').textContent = currentUser.name;
      document.getElementById('welcomeUser').textContent = currentUser.name;
      document.getElementById('userBadge').classList.remove('hidden');

      updateUserStats();
      showView('dashboardView');
    }

    function logout() {
      localStorage.removeItem('costa_barista_user');
      currentUser = null;
      document.getElementById('userBadge').classList.add('hidden');
      showView('loginView');
    }

    function updateUserStats() {
      if (!currentUser) return;
      const history = JSON.parse(localStorage.getItem('costa_quiz_history') || '[]');
      const userHistory = history.filter(h => h.userId === currentUser.id);

      document.getElementById('statQuizzes').textContent = userHistory.length;
      const best = userHistory.reduce((max, h) => h.score > max ? h.score : max, 0);
      document.getElementById('statHighScore').textContent = `${best} / 20`;
    }

    function startNewQuiz() {
      const shuffled = [...MASTER_QUESTIONS].sort(() => 0.5 - Math.random());
      activeQuizQuestions = shuffled.slice(0, 20);
      userAnswers = {};
      currentQuestionIndex = 0;
      showView('quizView');
      renderQuestion();
    }

    function renderQuestion() {
      const qData = activeQuizQuestions[currentQuestionIndex];
      const total = activeQuizQuestions.length;

      document.getElementById('questionTracker').textContent = `Question ${currentQuestionIndex + 1} of ${total}`;
      document.getElementById('progressBar').style.width = `${((currentQuestionIndex + 1) / total) * 100}%`;
      document.getElementById('questionText').textContent = qData.q;

      const container = document.getElementById('optionsContainer');
      container.innerHTML = '';

      qData.o.forEach((optText, optIdx) => {
        const isSelected = userAnswers[currentQuestionIndex] === optIdx;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.onclick = () => selectOption(optIdx);
        btn.className = `w-full text-left p-4 rounded-xl border transition flex items-center justify-between ${
          isSelected 
            ? 'bg-costa-burgundy/10 border-costa-burgundy text-costa-burgundy font-bold shadow-sm' 
            : 'bg-slate-50 hover:bg-slate-100 border-slate-200 text-slate-700 font-medium'
        }`;

        btn.innerHTML = `
          <div class="flex items-center space-x-3">
            <span class="w-7 h-7 rounded-lg text-xs flex items-center justify-center font-bold ${
              isSelected ? 'bg-costa-burgundy text-white' : 'bg-white border border-slate-300 text-slate-500'
            }">${String.fromCharCode(65 + optIdx)}</span>
            <span>${optText}</span>
          </div>
          ${isSelected ? '<i data-lucide="check" class="w-5 h-5 text-costa-burgundy"></i>' : ''}
        `;
        container.appendChild(btn);
      });

      document.getElementById('prevBtn').style.visibility = currentQuestionIndex === 0 ? 'hidden' : 'visible';
      if (currentQuestionIndex === total - 1) {
        document.getElementById('nextBtn').classList.add('hidden');
        document.getElementById('submitBtn').classList.remove('hidden');
      } else {
        document.getElementById('nextBtn').classList.remove('hidden');
        document.getElementById('submitBtn').classList.add('hidden');
      }

      lucide.createIcons();
    }

    function selectOption(optIndex) {
      userAnswers[currentQuestionIndex] = optIndex;
      renderQuestion();
    }

    function navigateQuestion(direction) {
      currentQuestionIndex += direction;
      renderQuestion();
    }

    function confirmSubmitQuiz() {
      let score = 0;
      activeQuizQuestions.forEach((qData, idx) => {
        if (userAnswers[idx] === qData.a) {
          score++;
        }
      });

      const history = JSON.parse(localStorage.getItem('costa_quiz_history') || '[]');
      history.push({
        userId: currentUser.id,
        name: currentUser.name,
        store: currentUser.store,
        score: score,
        total: 20,
        percentage: Math.round((score / 20) * 100),
        date: new Date().toLocaleDateString('en-GB')
      });
      localStorage.setItem('costa_quiz_history', JSON.stringify(history));

      renderResults(score);
      renderLeaderboard();
      renderMiniLeaderboard();
      updateUserStats();
    }

    function renderResults(score) {
      showView('resultView');
      const percentage = Math.round((score / 20) * 100);

      const scoreBadge = document.getElementById('scoreBadge');
      if (percentage >= 85) {
        scoreBadge.className = 'w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-extrabold bg-emerald-100 text-emerald-700 shadow-lg';
        scoreBadge.innerHTML = '🏆';
        document.getElementById('resultTitle').textContent = 'Certification Passed!';
        document.getElementById('resultSubtitle').textContent = 'Excellent work! You demonstrated strong mastery of Costa Barista Standards.';
      } else {
        scoreBadge.className = 'w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-extrabold bg-amber-100 text-amber-700 shadow-lg';
        scoreBadge.innerHTML = '📚';
        document.getElementById('resultTitle').textContent = 'Review & Retake Recommended';
        document.getElementById('resultSubtitle').textContent = 'Review your incorrect answers below to prepare for your next attempt.';
      }

      document.getElementById('finalScoreText').textContent = `${score} / 20`;
      document.getElementById('finalPercentageText').textContent = `${percentage}%`;

      setReviewFilter('all');
    }

    function setReviewFilter(filterType) {
      activeFilter = filterType;

      const wrongCount = activeQuizQuestions.filter((q, idx) => userAnswers[idx] !== q.a).length;
      const correctCount = activeQuizQuestions.length - wrongCount;

      document.getElementById('filterAllBtn').textContent = `All (20)`;
      document.getElementById('filterWrongBtn').textContent = `Incorrect Only (${wrongCount})`;
      document.getElementById('filterCorrectBtn').textContent = `Correct Only (${correctCount})`;

      ['filterAllBtn', 'filterWrongBtn', 'filterCorrectBtn'].forEach(id => {
        document.getElementById(id).className = 'px-3 py-1.5 rounded-lg text-slate-500 hover:text-slate-800 transition';
      });

      if (filterType === 'all') document.getElementById('filterAllBtn').className = 'px-3 py-1.5 rounded-lg bg-white text-slate-800 shadow-sm font-bold';
      if (filterType === 'wrong') document.getElementById('filterWrongBtn').className = 'px-3 py-1.5 rounded-lg bg-red-500 text-white shadow-sm font-bold';
      if (filterType === 'correct') document.getElementById('filterCorrectBtn').className = 'px-3 py-1.5 rounded-lg bg-emerald-600 text-white shadow-sm font-bold';

      renderReviewCards();
    }

    function renderReviewCards() {
      const reviewContainer = document.getElementById('reviewContainer');
      reviewContainer.innerHTML = '';

      activeQuizQuestions.forEach((qData, idx) => {
        const userChoice = userAnswers[idx];
        const isCorrect = userChoice === qData.a;

        if (activeFilter === 'wrong' && isCorrect) return;
        if (activeFilter === 'correct' && !isCorrect) return;

        const card = document.createElement('div');
        card.className = `p-4 rounded-xl border transition ${
          isCorrect ? 'bg-emerald-50/60 border-emerald-200' : 'bg-red-50/70 border-red-300'
        }`;

        card.innerHTML = `
          <div class="flex items-start gap-3">
            <div class="mt-0.5 p-1 rounded-full ${isCorrect ? 'bg-emerald-500 text-white' : 'bg-red-500 text-white'}">
              <i data-lucide="${isCorrect ? 'check' : 'x'}" class="w-4 h-4"></i>
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <span class="text-xs font-bold uppercase tracking-wide ${isCorrect ? 'text-emerald-700' : 'text-red-700'}">
                  Question ${idx + 1} — ${isCorrect ? 'CORRECT' : 'INCORRECT'}
                </span>
              </div>
              <p class="font-bold text-slate-900 text-sm mt-1">${qData.q}</p>
              
              <div class="mt-3 space-y-2 text-xs">
                <!-- User's Answer -->
                <div class="p-2 rounded-lg ${isCorrect ? 'bg-emerald-100/60 text-emerald-900' : 'bg-red-100 text-red-900'} flex items-center justify-between">
                  <span><strong>Your Choice:</strong> ${userChoice !== undefined ? qData.o[userChoice] : 'Not Answered'}</span>
                  ${!isCorrect ? '<span class="font-extrabold text-red-600 uppercase text-[10px] bg-white px-2 py-0.5 rounded border border-red-200">WRONG</span>' : ''}
                </div>

                <!-- Correct Answer (Displayed if wrong) -->
                ${!isCorrect ? `
                  <div class="p-2 rounded-lg bg-emerald-100/80 text-emerald-900 flex items-center justify-between border border-emerald-300">
                    <span><strong>Correct Costa Standard:</strong> ${qData.o[qData.a]}</span>
                    <span class="font-extrabold text-emerald-700 uppercase text-[10px] bg-white px-2 py-0.5 rounded border border-emerald-300">CORRECT ANSWER</span>
                  </div>
                ` : ''}
              </div>
            </div>
          </div>
        `;
        reviewContainer.appendChild(card);
      });

      if (reviewContainer.innerHTML === '') {
        reviewContainer.innerHTML = `<p class="text-center text-slate-400 py-6 text-sm">No questions match this filter.</p>`;
      }

      lucide.createIcons();
    }

    function getTopScores() {
      const history = JSON.parse(localStorage.getItem('costa_quiz_history') || '[]');
      const userBests = {};
      history.forEach(item => {
        if (!userBests[item.userId] || item.score > userBests[item.userId].score) {
          userBests[item.userId] = item;
        }
      });
      return Object.values(userBests).sort((a, b) => b.score - a.score);
    }

    function renderLeaderboard() {
      const topScores = getTopScores();
      const tbody = document.getElementById('fullLeaderboardTable');
      tbody.innerHTML = '';

      if (topScores.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="py-4 text-center text-slate-400 italic">No quiz scores logged yet. Be the first!</td></tr>`;
        return;
      }

      topScores.forEach((item, rank) => {
        const tr = document.createElement('tr');
        tr.className = rank === 0 ? 'bg-amber-50/40 font-medium' : '';
        tr.innerHTML = `
          <td class="py-3 px-2 font-bold ${rank === 0 ? 'text-costa-gold' : 'text-slate-500'}">#${rank + 1}</td>
          <td class="py-3 px-2 font-semibold text-slate-800">${item.name}</td>
          <td class="py-3 px-2 text-slate-500">${item.store}</td>
          <td class="py-3 px-2 text-right font-bold text-costa-burgundy">${item.score} / 20 (${item.percentage}%)</td>
          <td class="py-3 px-2 text-right text-xs text-slate-400">${item.date}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function renderMiniLeaderboard() {
      const topScores = getTopScores().slice(0, 3);
      const container = document.getElementById('miniLeaderboard');
      container.innerHTML = '';

      if (topScores.length === 0) {
        container.innerHTML = `<p class="text-slate-400 text-xs italic">No scores recorded yet.</p>`;
        return;
      }

      topScores.forEach((item, index) => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between bg-slate-50 p-2 rounded-lg border border-slate-100';
        div.innerHTML = `
          <div class="flex items-center space-x-2">
            <span class="w-5 h-5 bg-costa-burgundy text-white text-xs font-bold rounded-full flex items-center justify-center">${index + 1}</span>
            <span class="font-semibold text-slate-700">${item.name} <span class="text-xs text-slate-400">(${item.store})</span></span>
          </div>
          <span class="font-extrabold text-costa-burgundy">${item.score}/20</span>
        `;
        container.appendChild(div);
      });
    }
  </script>
</body>
</html>
